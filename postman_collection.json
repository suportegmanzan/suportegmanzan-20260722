{
  "info": {
    "name": "Gestao de Colaboradores e Unidades",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Criar usuario (admin)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/usuarios",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"admin\",\n  \"senha\": \"123456\",\n  \"status\": 1\n}"
        }
      }
    },
    {
      "name": "2. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) { pm.collectionVariables.set('token', json.token); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"admin\",\n  \"senha\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "3. Listar usuarios",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/usuarios"
      }
    },
    {
      "name": "3.1 Listar usuarios por status",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/usuarios?status=1"
      }
    },
    {
      "name": "4. Atualizar usuario (senha/status)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/usuarios/1",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": 1\n}"
        }
      }
    },
    {
      "name": "5. Criar unidade",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/unidades",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"codigoUnidade\": \"UN01\",\n  \"nome\": \"Matriz\"\n}"
        }
      }
    },
    {
      "name": "6. Listar unidades",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/unidades"
      }
    },
    {
      "name": "7. Inativar unidade",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/unidades/1",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ativa\": false\n}"
        }
      }
    },
    {
      "name": "8. Criar colaborador",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/colaboradores",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"João da Silva\",\n  \"unidadeId\": 1,\n  \"usuarioId\": 1\n}"
        }
      }
    },
    {
      "name": "9. Listar colaboradores",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/colaboradores"
      }
    },
    {
      "name": "10. Atualizar colaborador",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/colaboradores/1",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"João da Silva Junior\",\n  \"unidadeId\": 1\n}"
        }
      }
    },
    {
      "name": "11. Remover colaborador",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/colaboradores/1"
      }
    }
  ]
}
